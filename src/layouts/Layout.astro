---
import { ClientRouter } from "astro:transitions";
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/600.css";
import "@fontsource/outfit/800.css";
import "@fontsource/jetbrains-mono/400.css";
import "@fontsource/jetbrains-mono/500.css";
import "@fontsource/jetbrains-mono/700.css";

import "../styles/global.css";

interface Props {
  title: string;
  desktopStickyHeader?: boolean;
}

const { title, desktopStickyHeader = false } = Astro.props;

const headerClass = desktopStickyHeader
  ? "sticky top-0 z-50 border-b border-neutral-800/50 bg-neutral-950/95 md:bg-neutral-950/80 md:backdrop-blur-md shadow-lg shadow-black/50 w-full"
  : "sticky md:relative top-0 z-50 border-b border-neutral-800/50 bg-neutral-950/95 md:bg-neutral-950/80 md:backdrop-blur-md shadow-lg shadow-black/50 w-full";
---

<!doctype html>
<html lang="en" class="scroll-pt-20 bg-neutral-950">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Personal website of Piyush Kumar Singh, BSMS at IISER Kolkata."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <meta name="generator" content={Astro.generator} />

    <!-- KaTeX CSS for rendering math formulas -->
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css"
      crossorigin="anonymous"
    />

    <!-- Self-Hosted Fonts are imported in the Astro frontmatter -->
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="text-neutral-100 text-base md:text-lg font-sans antialiased selection:bg-zinc-500/30 relative min-h-screen flex flex-col">
    <!-- Ambient Background Glows (Hidden on mobile for performance) -->
    <div class="fixed inset-0 z-[-1] pointer-events-none overflow-hidden hidden md:block">
      <div
        class="absolute top-[-10%] left-[-10%] w-[60%] md:w-[40%] h-[60%] md:h-[40%] rounded-full bg-neutral-700/20 blur-[80px] md:blur-[120px] transform-gpu"
      >
      </div>
      <div
        class="absolute bottom-[-10%] right-[-10%] w-[60%] md:w-[40%] h-[60%] md:h-[40%] rounded-full bg-zinc-900/20 blur-[80px] md:blur-[120px] transform-gpu"
      >
      </div>
    </div>

    <!-- Navigation -->
    <header class={headerClass}>
      <div class="relative z-10 w-full px-6 md:px-12 h-16 flex items-center justify-between">
        <a
          href="/"
          aria-label="Home"
          class="flex items-center gap-2.5 hover:opacity-80 transition-opacity group"
        >
          <div
            class="transition-transform duration-500 ease-out group-hover:scale-125"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="url(#logo-gradient)"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="animate-[spin_10s_linear_infinite]"
            >
              <defs>
                <linearGradient
                  id="logo-gradient"
                  x1="0%"
                  y1="0%"
                  x2="100%"
                  y2="100%"
                >
                  <stop offset="0%" stop-color="#a1a1aa"></stop>
                  <stop offset="100%" stop-color="#d4d4d4"></stop>
                </linearGradient>
              </defs>
              <circle cx="12" cy="12" r="2.5"></circle>
              <ellipse
                rx="10"
                ry="3.5"
                cx="12"
                cy="12"
                transform="rotate(30 12 12)"></ellipse>
              <ellipse
                rx="10"
                ry="3.5"
                cx="12"
                cy="12"
                transform="rotate(90 12 12)"></ellipse>
              <ellipse
                rx="10"
                ry="3.5"
                cx="12"
                cy="12"
                transform="rotate(150 12 12)"></ellipse>
            </svg>
          </div>
          <span
            class="hidden md:block text-xl font-bold tracking-tight text-transparent bg-clip-text bg-linear-to-r from-zinc-400 to-neutral-200"
          >
            Piyush Kumar Singh
          </span>
        </a>

        <!-- Desktop Nav -->
        <nav class="hidden md:flex gap-6 text-base font-medium text-neutral-300">
          <a href="/" class="hover:text-zinc-400 transition-colors">Home</a>
          <a href="/projects" class="hover:text-zinc-400 transition-colors">Projects</a>
          <a href="/blog" class="hover:text-zinc-400 transition-colors">Blog</a>
          <a href="/software" class="hover:text-zinc-400 transition-colors">Software</a>
          <a href="/about" class="hover:text-zinc-400 transition-colors">About</a>
          <a href="/contact" class="hover:text-zinc-400 transition-colors">Contact</a>
        </nav>

        <!-- Mobile Hamburger Button -->
        <button
          id="mobile-menu-btn"
          aria-label="Toggle Menu"
          class="md:hidden text-neutral-300 hover:text-white p-2 focus:outline-none"
        >
          <svg
            class="transition-all duration-300"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>

      <!-- Mobile Nav Menu -->
      <div
        id="mobile-menu"
        class="md:hidden absolute w-full left-0 top-16 bg-neutral-950/95 backdrop-blur-xl border-b border-neutral-800 shadow-xl shadow-black transition-all duration-300 ease-out opacity-0 -translate-y-4 pointer-events-none"
      >
        <nav
          class="flex flex-col p-6 gap-6 text-lg font-medium text-neutral-300"
        >
          <a href="/" class="hover:text-zinc-400 transition-colors">Home</a>
          <a href="/projects" class="hover:text-zinc-400 transition-colors">Projects</a>
          <a href="/blog" class="hover:text-zinc-400 transition-colors">Blog</a>
          <a href="/software" class="hover:text-zinc-400 transition-colors">Software</a>
          <a href="/about" class="hover:text-zinc-400 transition-colors">About</a>
          <a href="/contact" class="hover:text-zinc-400 transition-colors">Contact</a>
        </nav>
      </div>
    </header>

    <main class="grow w-full flex flex-col">
      <slot />
    </main>

    <footer class="border-t border-neutral-800 py-4 mt-auto md:backdrop-blur-sm">
      <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-center items-center text-sm text-neutral-500">
        <p>&copy; 2026 Piyush Kumar Singh</p>
      </div>
    </footer>
    <script>
      // Track the global listener so we can clean it up between page navigations
      let clickOutsideListener: ((event: MouseEvent) => void) | null = null;

      document.addEventListener("astro:page-load", () => {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");

        // Remove any old event listeners by cloning the button (safeguard against duplicate listeners on client-side routing)
        if (btn && menu) {
          const newBtn = btn.cloneNode(true) as HTMLElement;
          btn.parentNode?.replaceChild(newBtn, btn);

          const toggleMenu = () => {
            menu.classList.toggle("opacity-0");
            menu.classList.toggle("-translate-y-4");
            menu.classList.toggle("pointer-events-none");

            // Animate the hamburger button itself
            const svg = newBtn.querySelector("svg");
            if (svg) {
              svg.classList.toggle("rotate-90");
              svg.classList.toggle("scale-110");
            }
          };

          newBtn.addEventListener("click", toggleMenu);

          // Click-outside to close logic
          if (clickOutsideListener) {
            document.removeEventListener("click", clickOutsideListener);
          }

          clickOutsideListener = (event: MouseEvent) => {
            const isMenuOpen = !menu.classList.contains("opacity-0");
            if (isMenuOpen) {
              const target = event.target as Node;
              if (!menu.contains(target) && !newBtn.contains(target)) {
                toggleMenu();
              }
            }
          };

          document.addEventListener("click", clickOutsideListener);
        }

        // Global Intersection Observer for scroll animations
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.1,
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("animate-reveal");
            } else {
              entry.target.classList.remove("animate-reveal");
            }
          });
        }, observerOptions);

        const initReveals = () => {
          const loadElements = document.querySelectorAll(".reveal-on-load");
          loadElements.forEach((el) => el.classList.add("animate-reveal"));

          const scrollElements = document.querySelectorAll(".reveal-on-scroll");
          scrollElements.forEach((el) => observer.observe(el));
        };

        initReveals();
      });
    </script>

    <style is:global>
      /* Fix Expressive Code border radius glitch where the inner code block rounds its top corners underneath the title bar */
      .expressive-code.has-title pre,
      .expressive-code figure:has(.header) pre,
      .expressive-code figure:has(figcaption) pre {
        border-top-left-radius: 0 !important;
        border-top-right-radius: 0 !important;
      }
    </style>
  </body>
</html>
