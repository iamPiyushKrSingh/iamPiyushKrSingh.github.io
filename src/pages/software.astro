---
import Layout from "../layouts/Layout.astro";
---

<Layout title="System Terminal | Piyush Kumar Singh">
  <div
    style="height: calc(100vh - 182px);"
    class="max-w-[100rem] w-full mx-auto px-4 md:px-8 py-4 md:py-6 flex flex-col items-center justify-center min-h-100"
  >
    <!-- Massive Interactive Terminal -->
    <div
      class="w-full h-full bg-[#1e1e1e]/90 backdrop-blur-2xl rounded-2xl border border-neutral-700/50 shadow-2xl flex flex-col overflow-hidden font-mono text-sm sm:text-base relative min-h-0"
    >
      <!-- Terminal Header -->
      <div
        class="bg-[#2d2d2d]/90 border-b border-neutral-700/50 px-4 py-3 flex items-center gap-2 select-none shrink-0"
      >
        <div class="flex gap-2">
          <div class="w-3.5 h-3.5 rounded-full bg-[#ff5f56] shadow-sm"></div>
          <div class="w-3.5 h-3.5 rounded-full bg-[#ffbd2e] shadow-sm"></div>
          <div class="w-3.5 h-3.5 rounded-full bg-[#27c93f] shadow-sm"></div>
        </div>
        <div
          class="mx-auto text-neutral-400 text-xs sm:text-sm font-medium tracking-wide"
        >
          piyush@linux:~
        </div>
      </div>

      <!-- Terminal Body -->
      <div
        class="p-6 grow overflow-y-auto"
        id="terminal-body"
        style="scrollbar-width: thin; scrollbar-color: #6272a4 transparent;"
      >
        <div class="text-[#bd93f9] mb-2 font-bold text-lg">
          System Booting...
        </div>
        <div class="text-[#50fa7b]/80 mb-1">Loading kernel modules... [OK]</div>
        <div class="text-[#50fa7b]/80 mb-1">
          Mounting virtual file systems... [OK]
        </div>
        <div class="text-[#6272a4] mb-6 mt-4 italic">
          Type 'help' to see a list of available commands. Try 'fastfetch'
          first!
        </div>

        <div id="terminal-output" class="flex flex-col gap-1"></div>

        <div class="flex items-center gap-3 mt-4">
          <span
            id="prompt-symbol"
            class="text-[#50fa7b] font-bold whitespace-nowrap shrink-0 transition-colors"
            >piyush@linux ❯</span
          >
          <div class="relative grow">
            <!-- Ghost text for autosuggestion -->
            <div
              id="ghost-text"
              class="absolute inset-0 text-[#6272a4] pointer-events-none flex items-center whitespace-pre"
            >
            </div>
            <!-- Actual input -->
            <input
              type="text"
              id="terminal-input"
              class="w-full bg-transparent outline-none text-[#f8f8f2] border-none focus:ring-0 p-0 text-base relative z-10"
              autocomplete="off"
              spellcheck="false"
              autofocus
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById("terminal-input") as HTMLInputElement;
    const output = document.getElementById("terminal-output");
    const body = document.getElementById("terminal-body");
    const ghostText = document.getElementById("ghost-text");
    const promptSymbol = document.getElementById("prompt-symbol");

    if (!input || !output || !body || !ghostText || !promptSymbol) return;

    let lastCommandFailed =
      sessionStorage.getItem("lastCommandFailed") === "true";
    let savedHistory = sessionStorage.getItem("commandHistory");
    let commandHistory: string[] = savedHistory ? JSON.parse(savedHistory) : [];
    let historyIndex = -1;

    // Apply initial prompt color based on saved state
    if (lastCommandFailed) {
      promptSymbol.classList.replace("text-[#50fa7b]", "text-[#ff5f56]");
    }

    // Clear state on hard reload (Ctrl+Shift+R)
    document.addEventListener("keydown", (e) => {
      if (e.ctrlKey && e.shiftKey && (e.key === "r" || e.key === "R")) {
        sessionStorage.removeItem("terminalState");
        sessionStorage.removeItem("lastCommandFailed");
        sessionStorage.removeItem("commandHistory");
      }
    });

    // Restore state from sessionStorage
    const savedState = sessionStorage.getItem("terminalState");
    if (savedState) {
      output.innerHTML = savedState;
      setTimeout(() => {
        body.scrollTop = body.scrollHeight;
      }, 10);
    }

    // Focus input when clicking anywhere on the terminal body
    body.addEventListener("click", () => {
      // Don't steal focus if they are trying to select text
      if (window.getSelection()?.toString() === "") {
        input.focus();
      }
    });

    const commands: Record<string, string | (() => string)> = {
      help: `Available commands:
  help      - Show this message
  whoami    - Print user information
  fastfetch - Display system information
  stack     - List my complete development stack
  skills    - List technical skills
  cat       - Concatenate files and print on the standard output
  clear     - Clear the terminal screen
  echo      - Print text (e.g., echo hello)`,

      whoami: `piyush
Role: 5th-year BSMS Student
Major: Physics
Minor: Mathematics
Institution: IISER Kolkata`,

      stack: `OS: I use Arch BTW (Niri)
Editor: VS Code & Neovim
Core: Julia, Python, C++, JavaScript, HTML/CSS
Frontend: Astro, React, TailwindCSS`,

      fastfetch: () => {
        return `<div class="flex flex-col md:flex-row gap-6 mt-4 mb-4 items-start">
  <div class="text-[#bd93f9] font-bold leading-tight whitespace-pre text-sm md:text-base">
      /&#92;
     /  &#92;
    /    &#92;
   /      &#92;
  /   ,,   &#92;
 /   |  |   &#92;
/____|  |____&#92;
  </div>
  <div class="text-sm md:text-base text-[#f8f8f2]">
    <div class="text-[#bd93f9] font-bold">piyush@linux</div>
    <div class="text-[#6272a4]">---------------------</div>
    <div><span class="text-[#8be9fd] font-bold">OS</span>: Arch Linux x86_64</div>
    <div><span class="text-[#8be9fd] font-bold">WM</span>: Niri (26.04)</div>
    <div><span class="text-[#8be9fd] font-bold">Uptime</span>: 5 years, 2 months</div>
    <div><span class="text-[#8be9fd] font-bold">Shell</span>: fish 4.7.1</div>
    <div><span class="text-[#8be9fd] font-bold">Editor</span>: VS Code & Neovim</div>
  </div>
</div>`;
      },

      skills: `Languages: Julia, Python, C++, JavaScript, HTML/CSS
Frameworks: Astro, Hugo, React, TailwindCSS
Tools: Linux, Git, Docker, LaTeX
Physics: Quantum Field Theory, String Theory, Computational Modeling`,
    };

    const virtualFS: Record<string, string> = {
      "secret.txt": "You found the easter egg!",
      "todo.md": `# Goals
      - [x] Build interactive terminal
      - [ ] Unify General Relativity and Quantum Mechanics
      - [ ] Buy groceries`,
      "profile.jpg":
        '<div class="mt-2 mb-2"><div class="w-32 h-32 rounded-2xl border border-neutral-700 bg-neutral-800 flex items-center justify-center text-zinc-500 overflow-hidden"><svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div><div class="text-xs text-neutral-500 mt-2 font-mono">[Image binary data decoded and rendered inline]</div></div>',
    };

    const allCommands = [...Object.keys(commands), "clear", "echo", "cat"];
    let currentSuggestion = "";

    // Fish-like Autosuggestion logic
    input.addEventListener("input", () => {
      const val = input.value;
      if (!val) {
        ghostText.textContent = "";
        ghostText.classList.add("hidden");
        currentSuggestion = "";
        return;
      }

      let match = "";
      const parts = val.toLowerCase().split(" ");

      if (parts.length === 1) {
        match = allCommands.find((c) => c.startsWith(parts[0])) || "";
      } else if (parts[0] === "cat" && parts.length === 2) {
        // Tab completion for filenames if using 'cat'
        const fileMatch = Object.keys(virtualFS).find((f) =>
          f.toLowerCase().startsWith(parts[1]),
        );
        if (fileMatch) {
          match = `cat ${fileMatch}`;
        }
      }

      if (match) {
        // We use a trick: render the matched part as invisible, and the rest as visible, so it perfectly overlays the input
        // Using original case for the suggested part
        const remaining = match.substring(val.length);
        ghostText.innerHTML = `<span class="opacity-0">${val}</span>${remaining}`;
        ghostText.classList.remove("hidden");
        currentSuggestion = match;
      } else {
        ghostText.textContent = "";
        ghostText.classList.add("hidden");
        currentSuggestion = "";
      }
    });

    input.addEventListener("keydown", (e) => {
      // Tab completion
      if (e.key === "Tab") {
        e.preventDefault();
        if (currentSuggestion) {
          input.value = currentSuggestion;
          // Trigger input event to clear ghost text
          input.dispatchEvent(new Event("input"));
        }
      }

      // Command History Navigation
      if (e.key === "ArrowUp") {
        e.preventDefault();
        if (historyIndex > 0) {
          historyIndex--;
          input.value = commandHistory[historyIndex];
          input.dispatchEvent(new Event("input")); // update ghost text
        } else if (historyIndex === -1 && commandHistory.length > 0) {
          historyIndex = commandHistory.length - 1;
          input.value = commandHistory[historyIndex];
          input.dispatchEvent(new Event("input"));
        }
      }

      if (e.key === "ArrowDown") {
        e.preventDefault();
        if (historyIndex !== -1 && historyIndex < commandHistory.length - 1) {
          historyIndex++;
          input.value = commandHistory[historyIndex];
          input.dispatchEvent(new Event("input"));
        } else if (historyIndex === commandHistory.length - 1) {
          historyIndex = -1;
          input.value = "";
          input.dispatchEvent(new Event("input"));
        }
      }

      if (e.key === "Enter") {
        const cmdString = input.value.trim();
        input.value = "";
        input.dispatchEvent(new Event("input")); // clear ghost text

        if (!cmdString) return;

        // Add to history
        if (
          commandHistory.length === 0 ||
          commandHistory[commandHistory.length - 1] !== cmdString
        ) {
          commandHistory.push(cmdString);
          sessionStorage.setItem(
            "commandHistory",
            JSON.stringify(commandHistory),
          );
        }
        historyIndex = -1;

        // Print the command that was just run (color matches the previous command's success state)
        const promptColor = lastCommandFailed
          ? "text-[#ff5f56]"
          : "text-[#50fa7b]";
        const cmdLine = document.createElement("div");
        cmdLine.innerHTML = `<span class="${promptColor} font-bold whitespace-nowrap shrink-0">piyush@linux ~ $</span> <span class="text-[#f8f8f2]">${cmdString}</span>`;
        cmdLine.className = "mt-2";
        output.appendChild(cmdLine);

        // Process command
        const args = cmdString.split(" ");
        const cmd = args[0].toLowerCase();

        let response = "";

        if (cmd === "clear") {
          output.innerHTML = "";
          sessionStorage.removeItem("terminalState");
          sessionStorage.removeItem("lastCommandFailed");
          lastCommandFailed = false;
          promptSymbol.classList.replace("text-[#ff5f56]", "text-[#50fa7b]");
          return;
        } else if (cmd === "echo") {
          response = args.slice(1).join(" ");
          lastCommandFailed = false;
        } else if (cmd === "ls") {
          response = Object.keys(virtualFS)
            .map((f) => `<span class="text-[#8be9fd] mr-4">${f}</span>`)
            .join("");
          lastCommandFailed = false;
        } else if (cmd === "cat") {
          if (args.length < 2) {
            response = "cat: missing file operand";
            lastCommandFailed = true;
          } else {
            const fileName = args[1];
            if (virtualFS[fileName]) {
              response = virtualFS[fileName];
              lastCommandFailed = false;
            } else {
              response = `cat: ${fileName}: No such file or directory`;
              lastCommandFailed = true;
            }
          }
        } else if (commands[cmd]) {
          const res = commands[cmd];
          response = typeof res === "function" ? res() : res;
          lastCommandFailed = false;
        } else {
          response = `bash: ${cmd}: command not found`;
          lastCommandFailed = true;
        }

        // Update current prompt color and persist state
        if (lastCommandFailed) {
          promptSymbol.classList.replace("text-[#50fa7b]", "text-[#ff5f56]");
        } else {
          promptSymbol.classList.replace("text-[#ff5f56]", "text-[#50fa7b]");
        }
        sessionStorage.setItem(
          "lastCommandFailed",
          lastCommandFailed.toString(),
        );

        // Print response
        if (response) {
          const resLine = document.createElement("div");
          // Escape HTML for text responses to prevent injection, but allow raw HTML for specific commands
          if (
            cmd === "fastfetch" ||
            cmd === "ls" ||
            (cmd === "cat" && virtualFS[args[1]])
          ) {
            resLine.className = "text-[#f8f8f2] mt-1";
            resLine.innerHTML = response;
          } else {
            resLine.className = "text-[#f8f8f2] whitespace-pre-wrap mt-1";
            resLine.textContent = response;
          }
          resLine.classList.add("mb-3");
          output.appendChild(resLine);
        }

        // Save state after output is updated
        sessionStorage.setItem("terminalState", output.innerHTML);

        // Scroll to bottom
        setTimeout(() => {
          body.scrollTop = body.scrollHeight;
        }, 10);
      }
    });
  });
</script>
