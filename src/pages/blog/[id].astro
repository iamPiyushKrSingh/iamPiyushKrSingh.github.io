---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { parseMathInText } from "../../utils/parseMath";
import "../../styles/markdown.css";

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const tocTree: any[] = [];
let currentH2: any = null;

for (const h of headings) {
  if (h.depth === 2) {
    currentH2 = { ...h, children: [] as any[] };
    tocTree.push(currentH2);
  } else if (h.depth === 3) {
    if (currentH2) {
      currentH2.children.push(h);
    } else {
      // If there's an h3 before any h2, treat it as a top-level node
      tocTree.push({ ...h, children: [] as any[] });
    }
  }
}
---

<Layout title={`${post.data.title} | Piyush Kumar Singh`} desktopStickyHeader={true}>
  <div class="max-w-[100rem] mx-auto px-6 md:px-12 pt-12 pb-24">
    <article>
      <header class="mb-4 md:mb-16 border-b border-neutral-800 pb-6 md:pb-10 text-center max-w-5xl mx-auto">
        <div class="text-sm font-medium text-zinc-400/80 mb-6 uppercase tracking-widest">
          {post.data.pubDate.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </div>
        <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white mb-6 font-[Outfit] leading-tight" transition:name={`title-${post.id}`} set:html={parseMathInText(post.data.title)} />
        <p class="text-xl text-neutral-400 italic max-w-3xl mx-auto" set:html={parseMathInText(post.data.description)} />
      </header>

      <div class="flex flex-col lg:flex-row gap-12 lg:gap-20 justify-center">
        <div class="grow max-w-5xl w-full min-w-0">
          <div class="prose-global md:prose-lg mx-auto">
            <Content />
          </div>
        </div>

      {tocTree.length > 0 && (
        <aside class="hidden lg:block w-72 shrink-0 border-l border-neutral-800/60 pl-8 py-2">
          <div class="sticky top-28 flex flex-col max-h-[calc(100vh-8rem)] overflow-y-auto overscroll-contain pr-4 pb-4">
            <h4 class="text-neutral-200 font-bold mb-4 font-[Outfit] border-b border-neutral-800 pb-2 uppercase tracking-wider text-base">
              Contents
            </h4>
            
            <ul class="relative flex flex-col ml-1">
              {tocTree.map((h2_node) => {
                return (
                  <li class="relative">
                    <a href={`#${h2_node.slug}`} class="group toc-link flex items-start text-base text-neutral-400 hover:translate-x-1 transition-transform duration-300 py-1.5" title={h2_node.text}>
                      <span class="toc-text group-hover:text-zinc-200 transition-colors duration-300 leading-snug font-medium truncate">
                        {h2_node.text}
                      </span>
                    </a>

                    {h2_node.children.length > 0 && (
                      <ul class="relative flex flex-col ml-3">
                        {h2_node.children.map((h3_node: any, j: number) => {
                          const isLastH3 = j === h2_node.children.length - 1;
                          return (
                            <li class="relative">
                              {/* Vertical line for H3 */}
                              {!isLastH3 && <div class="absolute left-0 top-0 bottom-0 w-px bg-neutral-700/60"></div>}
                              {isLastH3 && <div class="absolute left-0 top-0 h-4 w-px bg-neutral-700/60"></div>}

                              {/* Horizontal line for H3 */}
                              <div class="absolute left-0 top-4 w-4 h-px bg-neutral-700/60"></div>

                              <a href={`#${h3_node.slug}`} class="group toc-link flex items-start text-sm text-neutral-400 hover:translate-x-1 transition-transform duration-300 pl-6 py-1.5" title={h3_node.text}>
                                <span class="toc-text group-hover:text-zinc-200 transition-colors duration-300 leading-snug truncate">
                                  {h3_node.text}
                                </span>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    )}
                  </li>
                );
              })}
            </ul>
          </div>
        </aside>
      )}
      </div>
    </article>
  </div>

  {tocTree.length > 0 && (
    <>
      <!-- Mobile TOC Button -->
      <button id="mobile-toc-btn" class="lg:hidden fixed bottom-6 right-6 z-50 p-3.5 bg-zinc-800 text-neutral-200 rounded-full shadow-lg shadow-black/80 border border-neutral-700 hover:bg-zinc-700 transition-colors focus:outline-none focus:ring-2 focus:ring-zinc-400" aria-label="Table of Contents">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
      </button>

      <!-- Mobile TOC Panel -->
      <div id="mobile-toc-modal" class="lg:hidden fixed inset-0 z-60 pointer-events-none flex flex-col justify-end">
        <div id="mobile-toc-backdrop" class="absolute inset-0 bg-neutral-950/80 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
        <div id="mobile-toc-content" class="relative w-full max-h-[75vh] bg-neutral-900 border-t border-neutral-800 rounded-t-3xl shadow-[0_-10px_40px_rgba(0,0,0,0.5)] overflow-y-auto overscroll-contain transform translate-y-full transition-transform duration-300 ease-out p-6 pointer-events-auto flex flex-col">
          <div class="flex items-center justify-between mb-4 border-b border-neutral-800 pb-4 shrink-0">
            <h4 class="text-neutral-200 font-bold font-[Outfit] tracking-wider text-lg">Table of Contents</h4>
            <button id="mobile-toc-close" class="text-neutral-400 hover:text-white p-2 bg-neutral-800 rounded-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
          </div>
          
          <ul class="relative flex flex-col ml-1 pb-10">
              {tocTree.map((h1) => {
                return (
                  <li class="relative">
                    <a href={`#${h1.slug}`} class="group toc-link flex items-start text-base text-neutral-400 hover:translate-x-1 transition-transform duration-300 py-1.5" title={h1.text}>
                      <span class="toc-text group-hover:text-zinc-200 transition-colors duration-300 leading-snug font-medium truncate">
                        {h1.text}
                      </span>
                    </a>
                    {h1.children.length > 0 && (
                      <ul class="relative flex flex-col ml-3">
                        {h1.children.map((h2: any, j: number) => {
                          const isLastH2 = j === h1.children.length - 1;
                          return (
                            <li class="relative">
                              {!isLastH2 && <div class="absolute left-0 top-0 bottom-0 w-px bg-neutral-700/60"></div>}
                              {isLastH2 && <div class="absolute left-0 top-0 h-4 w-px bg-neutral-700/60"></div>}
                              <div class="absolute left-0 top-4 w-4 h-px bg-neutral-700/60"></div>
                              <a href={`#${h2.slug}`} class="group toc-link flex items-start text-sm text-neutral-400 hover:translate-x-1 transition-transform duration-300 pl-6 py-1.5" title={h2.text}>
                                <span class="toc-text group-hover:text-zinc-200 transition-colors duration-300 leading-snug truncate">
                                  {h2.text}
                                </span>
                              </a>
                            </li>
                          );
                        })}
                      </ul>
                    )}
                  </li>
                );
              })}
          </ul>
        </div>
      </div>
    </>
  )}
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {
    // TOC Highlighting Logic
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -80% 0px',
      threshold: 1.0
    };

    const tocLinks = document.querySelectorAll('.toc-link');
    const headings = document.querySelectorAll('article h1, article h2');

    // Keep track of which headings are currently visible
    let activeId = '';

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeId = entry.target.id;
        }
      });
      
      // If no heading is intersecting at this exact moment, 
      // we don't clear the activeId, so it keeps the last one highlighted!
      
      tocLinks.forEach(link => {
        if (link.getAttribute('href') === `#${activeId}`) {
          link.classList.add('is-active');
        } else {
          link.classList.remove('is-active');
        }
      });
    }, observerOptions);

    headings.forEach(h => observer.observe(h));

    // Mobile TOC Logic
    const mobileTocBtn = document.getElementById('mobile-toc-btn');
    const mobileTocModal = document.getElementById('mobile-toc-modal');
    const mobileTocBackdrop = document.getElementById('mobile-toc-backdrop');
    const mobileTocContent = document.getElementById('mobile-toc-content');
    const mobileTocClose = document.getElementById('mobile-toc-close');

    if (mobileTocBtn && mobileTocModal) {
      const toggleMenu = () => {
        const isOpen = !mobileTocModal.classList.contains('pointer-events-none');
        if (isOpen) {
          mobileTocModal.classList.add('pointer-events-none');
          mobileTocBackdrop?.classList.add('opacity-0');
          mobileTocContent?.classList.add('translate-y-full');
        } else {
          mobileTocModal.classList.remove('pointer-events-none');
          mobileTocBackdrop?.classList.remove('opacity-0');
          mobileTocContent?.classList.remove('translate-y-full');
        }
      };

      mobileTocBtn.addEventListener('click', toggleMenu);
      mobileTocClose?.addEventListener('click', toggleMenu);
      mobileTocBackdrop?.addEventListener('click', toggleMenu);

      // Close modal when a link is clicked
      const mobileLinks = mobileTocModal.querySelectorAll('.toc-link');
      mobileLinks.forEach(link => {
        link.addEventListener('click', () => {
          toggleMenu();
        });
      });
    }
  });
</script>

<style is:global>
  article {
    counter-reset: h2-counter h3-counter figure-counter eq-counter;
  }
  
  /* Section Numbering */
  article .prose-global h2 {
    counter-increment: h2-counter;
    counter-reset: h3-counter;
  }
  article .prose-global h2::before {
    content: "§" counter(h2-counter) ". ";
    color: #a1a1aa; /* zinc-400 */
    margin-right: 0.5rem;
  }
  
  /* Sub-section Numbering */
  article .prose-global h3 {
    counter-increment: h3-counter;
  }
  article .prose-global h3::before {
    content: "§" counter(h2-counter) "." counter(h3-counter) " ";
    color: #a1a1aa; /* zinc-400 */
    margin-right: 0.5rem;
  }

  /* Figure Numbering */
  article figure:not(.frame) figcaption {
    counter-increment: figure-counter;
  }
  article figure:not(.frame) figcaption::before {
    content: "Figure " counter(figure-counter) ": ";
    font-weight: 700;
    color: #d4d4d4;
  }

  /* Internal References (Sections, Equations, Footnotes) */
  article .prose-global a[href^="#"] {
    color: #e4e4e7; /* zinc-200, slightly brighter than standard links */
    text-decoration: underline;
    text-decoration-style: dotted;
    text-underline-offset: 4px;
    transition: all 0.2s ease-in-out;
  }
  article .prose-global a[href^="#"]:hover {
    color: #ffffff;
    text-decoration-style: solid;
  }

  /* Remove redundant injected quotation marks from Tailwind Typography */
  article blockquote p::before,
  article blockquote p::after {
    content: none !important;
  }

  /* TOC Active State Styles */
  .toc-link.is-active {
    transform: translateX(0.25rem);
  }
  .toc-link.is-active .toc-text {
    color: #e4e4e7 !important; /* zinc-200 */
  }
</style>
