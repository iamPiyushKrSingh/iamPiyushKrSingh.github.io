---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import profileImg from "../assets/profile.jpg";
import { parseMathInText } from "../utils/parseMath";

const posts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const recentPosts = posts.slice(0, 3);

import { iconMap } from "../utils/iconMap";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .slice(0, 3)
  .map((p) => ({
    ...p,
    data: {
      ...p.data,
      icon: iconMap[p.data.icon] || p.data.icon || iconMap.code,
    },
  }));
---

<Layout title="Piyush Kumar Singh" desktopStickyHeader={false}>
  <!-- Hero Section: Full Screen with Image -->
  <section
    class="w-full relative px-6 md:px-12 pt-12 pb-24 overflow-hidden"
  >
    <div
      class="absolute inset-0 pointer-events-none bg-[radial-gradient(ellipse_at_center,rgba(161,161,170,0.12),transparent_70%)]"
    >
    </div>
    <div
      class="relative z-10 max-w-360 mx-auto flex flex-col md:flex-row items-center justify-center gap-12 lg:gap-24"
    >
      <!-- Image Left -->
      <div class="w-full md:w-5/12 flex justify-center md:justify-end">
        <div
          class="relative w-80 h-80 md:w-96 md:h-96 rounded-full p-1 md:p-2 border border-neutral-700 bg-neutral-900/50 shadow-xl shadow-zinc-500/10 transform-gpu"
        >
          <Image
            src={profileImg}
            alt="Piyush Kumar Singh"
            width={600}
            height={600}
            quality="max"
            class="w-full h-full object-cover rounded-full"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            transition:name="profile-image"
          />
          <div
            class="absolute inset-0 rounded-full border border-zinc-500/30 ring-1 ring-zinc-500/10 pointer-events-none"
          >
          </div>
        </div>
      </div>
      <!-- Text Right -->
      <div class="w-full md:w-7/12 text-center md:text-left">
        <div
          class="inline-block mb-4 px-3 py-1 rounded-full border border-neutral-700 bg-neutral-800/50 text-zinc-300 text-sm font-medium backdrop-blur-sm"
        >
          Physics Major @ IISER Kolkata
        </div>
        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight text-white mb-3 md:mb-6 font-[Outfit] min-h-20 md:min-h-0"
          transition:name="page-title"
        >
          Exploring the <br class="hidden md:block" />
          <span
            id="typewriter"
            class="text-transparent bg-clip-text bg-linear-to-r from-zinc-400 to-neutral-200 border-r-4 border-zinc-400 pr-1 animate-pulse whitespace-nowrap"
          ></span>
        </h1>
        <p
          class="text-xl md:text-2xl text-neutral-400 mb-10 max-w-2xl leading-relaxed mx-auto md:mx-0 opacity-0 translate-y-4 reveal-on-load delay-300"
        >
          Hi, I'm <strong class="text-neutral-100">Piyush Kumar Singh</strong>.
          I'm a 5th-year BSMS dual degree student majoring in Physics. My
          journey delves deep into Quantum Field Theory and String Theory.
        </p>

        <div
          class="flex flex-wrap justify-center md:justify-start gap-4 opacity-0 translate-y-4 reveal-on-load delay-500"
        >
          <a
            href="/blog"
            class="px-8 py-3.5 bg-zinc-600 hover:bg-zinc-500 text-white font-semibold rounded-full transition-all shadow-[0_0_20px_rgba(161,161,170,0.3)] hover:shadow-[0_0_30px_rgba(161,161,170,0.5)] hover:-translate-y-0.5"
          >
            Read my blog
          </a>
          <a
            href="/about"
            class="px-8 py-3.5 bg-neutral-800 hover:bg-neutral-700 border border-neutral-700 text-neutral-100 font-semibold rounded-full transition-all"
          >
            About me
          </a>
        </div>
      </div>
    </div>
    <!-- Scroll Down Indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center opacity-0 translate-y-4 reveal-on-load delay-500">
      <span class="text-[10px] text-zinc-500 font-mono mb-1 uppercase tracking-widest">Scroll</span>
      <svg class="w-5 h-5 text-zinc-500 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </div>
  </section>

  <!-- Full Width Fading Gradient Divider -->
  <div class="w-full h-[1px] min-h-[1px] bg-linear-to-r from-transparent via-neutral-700 to-transparent"></div>

  <!-- Featured Projects Section -->
  {
    featuredProjects.length > 0 && (
      <section class="max-w-7xl mx-auto px-6 md:px-12 pt-8 pb-8">
        <div class="flex items-center justify-between mb-10 reveal-on-scroll">
          <h2 class="text-3xl font-bold font-[Outfit] text-white">
            Selected Projects
          </h2>
          <a
            href="/projects"
            class="text-sm font-medium text-zinc-400 hover:text-zinc-300 transition-colors flex items-center gap-1"
          >
            View all projects &rarr;
          </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 reveal-on-scroll delay-100">
          {featuredProjects.map((project) => (
            <a
              href={`/projects?id=${project.id}`}
              data-astro-reload
              class="project-card group bg-neutral-900/40 rounded-2xl border border-neutral-700 shadow-lg overflow-hidden transition-all duration-300 hover:bg-neutral-800/60 hover:-translate-y-1 hover:border-zinc-500/50 p-6 flex flex-col h-full transform-gpu"
            >
              <div class="flex items-center gap-4 mb-5">
                <div
                  class="bg-neutral-900/80 p-3 rounded-2xl border border-neutral-700/50 shadow-inner shrink-0"
                  set:html={project.data.icon}
                />
                <h3
                  class="text-xl font-bold font-[Outfit] text-white group-hover:text-zinc-400 transition-colors line-clamp-2"
                  set:html={parseMathInText(project.data.title)}
                />
              </div>

              <div class="flex flex-wrap gap-2 mb-5">
                {project.data.tags.slice(0, 3).map((tag) => (
                  <span class="px-3 py-1 rounded-full border border-neutral-700 bg-neutral-800/50 text-neutral-300 text-xs font-mono tracking-wide">
                    {tag}
                  </span>
                ))}
                {project.data.tags.length > 3 && (
                  <span class="px-3 py-1 rounded-full border border-neutral-700 bg-neutral-800/50 text-neutral-500 text-xs font-mono tracking-wide">
                    +{project.data.tags.length - 3}
                  </span>
                )}
              </div>

              <p
                class="text-neutral-400 text-sm leading-relaxed line-clamp-3 mb-6"
                set:html={parseMathInText(project.data.summary)}
              />

              <div class="mt-auto pt-4 border-t border-neutral-800/50 flex items-center justify-between text-zinc-500 text-sm font-medium">
                <span>View Details</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="transition-transform group-hover:translate-x-1"
                >
                  <path d="M5 12h14" />
                  <path d="m12 5 7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
        
        <!-- Fading Gradient Divider -->
        <div class="w-full h-[1px] min-h-[1px] bg-linear-to-r from-transparent via-neutral-700 to-transparent mt-16"></div>
      </section>
    )
  }

  <!-- Recent Posts Section -->
  <section class="max-w-7xl mx-auto px-6 md:px-12 pt-6 pb-12">
    <div class="flex items-center justify-between mb-10 reveal-on-scroll">
      <h2 class="text-3xl font-bold font-[Outfit] text-white">
        Recent Writings
      </h2>
      <a
        href="/blog"
        class="text-sm font-medium text-zinc-400 hover:text-zinc-300 transition-colors flex items-center gap-1"
      >
        View all posts &rarr;
      </a>
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 reveal-on-scroll delay-100"
    >
      {/* Latest Post - Large Bento Card */}
      {
        recentPosts.length > 0 && (
          <a
            href={`/blog/${recentPosts[0].id}/`}
            class="md:col-span-2 md:row-span-2 group flex flex-col justify-center bg-neutral-900/50 md:backdrop-blur-sm border border-neutral-700 rounded-2xl p-8 hover:border-zinc-500/50 hover:bg-neutral-800/50 transition-all hover:-translate-y-1 relative overflow-hidden transform-gpu"
          >
            <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity duration-500">
              <svg
                class="w-32 h-32 text-zinc-500"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path d="M12 0l-3 12h6zM3 15l9 9 9-9h-18z" />
              </svg>
            </div>

            <div class="text-xs uppercase tracking-widest text-zinc-400/80 mb-4 font-bold flex items-center gap-2 relative z-10">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-zinc-400 opacity-75" />
                <span class="relative inline-flex rounded-full h-2 w-2 bg-zinc-500" />
              </span>
              Latest Publication
            </div>
            <h3
              class="text-3xl font-bold text-white group-hover:text-zinc-300 transition-colors mb-4 font-[Outfit] relative z-10 line-clamp-4"
              title={recentPosts[0].data.title}
              transition:name={`title-${recentPosts[0].id}`}
              set:html={parseMathInText(recentPosts[0].data.title)}
            />
            <p
              class="text-neutral-400 text-base leading-relaxed relative z-10 max-w-2xl line-clamp-4"
              set:html={parseMathInText(recentPosts[0].data.description)}
            />
          </a>
        )
      }

      {/* Older Posts - Smaller Bento Cards */}
      {
        recentPosts.slice(1, 3).map((post) => (
          <a
            href={`/blog/${post.id}/`}
            class="md:col-span-1 md:row-span-1 group flex flex-col justify-center bg-neutral-900/50 md:backdrop-blur-sm border border-neutral-700 rounded-2xl p-6 hover:border-zinc-500/50 hover:bg-neutral-800/50 transition-all hover:-translate-y-1 min-h-35 transform-gpu"
          >
            <div class="text-xs text-neutral-500 mb-2 font-mono">
              {post.data.pubDate.toLocaleDateString("en-US", {
                month: "short",
                day: "numeric",
                year: "numeric",
              })}
            </div>
            <h3
              class="text-lg font-bold text-neutral-100 group-hover:text-zinc-300 transition-colors mb-2 leading-snug"
              transition:name={`title-${post.id}`}
              set:html={parseMathInText(post.data.title)}
            />
            <p
              class="text-neutral-400 text-sm leading-relaxed line-clamp-2"
              set:html={parseMathInText(post.data.description)}
            />
          </a>
        ))
      }

      {
        recentPosts.length === 0 && (
          <div class="md:col-span-3 min-h-[35vh] w-full flex flex-col items-center justify-center border border-dashed border-neutral-800 rounded-2xl bg-neutral-900/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-zinc-600 mb-4">
              <circle cx="12" cy="12" r="10"></circle>
              <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            <p class="text-zinc-400 font-medium text-lg">
              Stay tuned for posts
            </p>
            <p class="text-zinc-600 text-sm mt-1">
              The universe is still expanding.
            </p>
          </div>
        )
      }
    </div>
  </section>
</Layout>

<script>
  // Typewriter Effect
  const words = [
    "Quantum Field Theory",
    "String Theory",
    "Mathematics",
    "Code",
  ];
  let i = parseInt(sessionStorage.getItem("typewriterIndex") || "0");
  let timer: ReturnType<typeof setTimeout>;

  function typingEffect() {
    const word = words[i].split("");
    var loopTyping = function () {
      if (word.length > 0) {
        document.getElementById("typewriter")!.innerHTML += word.shift();
      } else {
        deletingEffect();
        return false;
      }
      timer = setTimeout(loopTyping, 120);
    };
    loopTyping();
  }

  function deletingEffect() {
    let word = words[i].split("");
    var loopDeleting = function () {
      if (word.length > 0) {
        word.pop();
        document.getElementById("typewriter")!.innerHTML = word.join("");
      } else {
        if (words.length > i + 1) {
          i++;
        } else {
          i = 0;
        }
        sessionStorage.setItem("typewriterIndex", i.toString());
        typingEffect();
        return false;
      }
      timer = setTimeout(loopDeleting, 60);
    };
    setTimeout(loopDeleting, 2000); // Pause before deleting
  }

  // Initialize typing immediately on first load
  const initTyping = () => {
    if (timer) clearTimeout(timer);
    const typewriterEl = document.getElementById("typewriter");
    if (typewriterEl) {
      typewriterEl.innerHTML = "";
      typingEffect();
    }
  };

  initTyping();

  // Re-run if user navigates back to the page via View Transitions
  document.addEventListener("astro:after-swap", initTyping);
</script>
