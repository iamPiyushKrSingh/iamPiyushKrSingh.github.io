---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contact | Piyush Kumar Singh">
  <div
    class="max-w-5xl mx-auto px-6 md:px-12 py-24 min-h-[70vh] flex flex-col justify-center"
  >
    <div class="text-center mb-16">
      <h1
        class="text-5xl md:text-7xl font-extrabold tracking-tight text-white mb-6 font-[Outfit]"
        transition:name="page-title"
      >
        Let's Connect
      </h1>
      <p
        class="text-xl md:text-2xl text-zinc-400 max-w-2xl mx-auto leading-relaxed"
      >
        I'm always open to discussing physics, math, and new research
        opportunities. Connect with me on social media or drop me an email.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
      <!-- Personal Email -->
      <a
        href="mailto:pksx9120+website@gmail.com"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-zinc-500/50 hover:bg-zinc-800/50 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-zinc-100/10 flex items-center justify-center text-zinc-300 group-hover:scale-110 group-hover:bg-zinc-100 group-hover:text-black transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
              d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">
            Personal Email
          </h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            pksx9120@gmail.com
          </p>
        </div>
      </a>

      <!-- Academic Email -->
      <a
        href="mailto:pks22ms027+website@iiserkol.ac.in"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-emerald-500/50 hover:bg-emerald-500/10 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-emerald-500/10 flex items-center justify-center text-emerald-400 group-hover:scale-110 group-hover:bg-emerald-500 group-hover:text-white transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9c0-1.1.9-2 2-2h2"
            ></path><path d="M18 14h-8"></path><path d="M15 18h-5"></path><path
              d="M10 6h8v4h-8V6Z"></path></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">
            Academic Email
          </h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            pks22ms027@iiserkol.ac.in
          </p>
        </div>
      </a>

      <!-- GitHub -->
      <a
        href="https://github.com/iamPiyushKrSingh"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-purple-500/50 hover:bg-purple-500/10 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-purple-500/10 flex items-center justify-center text-purple-400 group-hover:scale-110 group-hover:bg-purple-500 group-hover:text-white transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">GitHub</h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            @iamPiyushKrSingh
          </p>
        </div>
      </a>

      <!-- GitLab -->
      <a
        href="https://gitlab.com/iamPiyushKrSingh"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-orange-500/50 hover:bg-orange-500/10 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-orange-500/10 flex items-center justify-center text-orange-400 group-hover:scale-110 group-hover:bg-orange-500 group-hover:text-white transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="m22 13.29-3.33-10a.42.42 0 0 0-.14-.18.38.38 0 0 0-.22-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18l-2.26 6.67H8.32L6.1 3.26a.42.42 0 0 0-.1-.18.38.38 0 0 0-.26-.11.39.39 0 0 0-.23.07.42.42 0 0 0-.14.18L2 13.29a.74.74 0 0 0 .27.83L12 21l9.69-6.88a.71.71 0 0 0 .31-.83Z"
            ></path></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">GitLab</h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            @iamPiyushKrSingh
          </p>
        </div>
      </a>

      <!-- LinkedIn -->
      <a
        href="https://www.linkedin.com/in/iampiyushkrsingh/"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-blue-500/50 hover:bg-blue-500/10 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-400 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect width="4" height="12" x="2" y="9"></rect><circle
              cx="4"
              cy="4"
              r="2"></circle></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">
            LinkedIn
          </h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            Piyush Kumar Singh
          </p>
        </div>
      </a>

      <!-- Twitter / X -->
      <a
        href="https://twitter.com/iamPiyushKrSingh"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 bg-zinc-900/40 backdrop-blur-sm border border-white/5 rounded-2xl p-6 hover:border-sky-500/50 hover:bg-sky-500/10 transition-all hover:-translate-y-1"
      >
        <div
          class="w-14 h-14 rounded-full bg-sky-500/10 flex items-center justify-center text-sky-400 group-hover:scale-110 group-hover:bg-sky-500 group-hover:text-white transition-all shrink-0"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"
            ></path></svg
          >
        </div>
        <div class="overflow-hidden">
          <h3 class="text-xl font-bold text-zinc-100 font-[Outfit]">
            Twitter / X
          </h3>
          <p
            class="text-zinc-400 group-hover:text-zinc-300 transition-colors truncate"
          >
            @iamPiyushKrSingh
          </p>
        </div>
      </a>
    </div>
  </div>
</Layout>
